---
import BaseLayout from './BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import ReadingTime from '../components/ReadingTime.astro';
import TagList from '../components/TagList.astro';

interface Props {
  title: string;
  description?: string;
  date: Date;
  tags?: string[];
  content: string;
}

const { title, description, date, tags = [], content } = Astro.props;
---

<BaseLayout title={title} description={description}>
  <Header />
  <main style="max-width: var(--content-width); margin: 0 auto; padding: 2rem 1rem;">
    <article>
      <header style="margin-bottom: 2rem;">
        <h1>{title}</h1>
        <div style="display: flex; gap: 1rem; align-items: center; margin-top: 1rem; font-size: 0.9rem; color: var(--text-muted); font-variant: all-small-caps; letter-spacing: 0.08em;">
          <time datetime={date.toISOString()}>
            {date.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
          </time>
          <ReadingTime content={content} />
        </div>
        {tags.length > 0 && (
          <div style="margin-top: 1rem;">
            <TagList tags={tags} />
          </div>
        )}
        <hr style="margin-top: 1.5rem;" />
      </header>
      <div class="post-body">
        <slot />
      </div>
    </article>
  </main>
  <Footer />
</BaseLayout>
