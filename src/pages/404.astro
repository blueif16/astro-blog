---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<BaseLayout title="404 — Not Found">
  <Header />
  <main class="page-container">
    <div class="prose-container" style="padding: 8rem 0; text-align: center;">
      <h1 style="font-size: clamp(4rem, 10vw, 8rem); color: var(--border); margin-bottom: 1rem;">404</h1>
      <p style="font-family: var(--font-heading); font-size: 1.4rem; color: var(--text-muted); margin-bottom: 2rem;">
        This page wandered off.
      </p>
      <a href="/" style="font-family: var(--font-sans); font-size: 0.9rem;">
        &larr; Back home
      </a>
    </div>
  </main>
  <Footer />
</BaseLayout>
