---
interface Props {
  title: string;
  date: Date;
  section: string;
  slug: string;
}

const { title, date, section, slug } = Astro.props;
---

<div class="post-list-item">
  <h3 class="post-title">
    <a href={`/${section}/${slug}`}>{title}</a>
  </h3>
  <time class="post-date" datetime={date.toISOString()}>
    {date.toLocaleDateString('en-US', { month: 'short', day: 'numeric' })}
  </time>
</div>
